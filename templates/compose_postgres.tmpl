version: "3.8"

services:
    postgres:
        environment:
            - POSTGRES_USER=postgres
            - POSTGRES_PASSWORD=postgres
            - POSTGRES_DB=test
        image: postgres:latest
        logging:
            options:
                max-file: "3"
                max-size: 10m
        ports:
            - 5438:5432
        restart: always
        networks:
            - postgres_net

networks:
    postgres_net:
        driver: bridge